# Copy this file to .env and fill in your Supabase project values.
# Get them from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mercado Pago Configuration
# Get your credentials from: https://www.mercadopago.com.br/developers/panel/credentials
VITE_MERCADO_PAGO_PUBLIC_KEY=your_public_key_here

# Note: The following variables are configured as Supabase Edge Function secrets
# and should NOT be added to .env (they are server-side only):
# - MERCADO_PAGO_ACCESS_TOKEN (for API calls from webhook handler)
# - MERCADO_PAGO_WEBHOOK_SECRET (for webhook signature verification)
# - SUPABASE_SERVICE_ROLE_KEY (automatically available in Edge Functions)
